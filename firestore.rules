
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is the super admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'chetanmadhav4@gmail.com';
    }

    // Master collection of orders for the admin tracker
    match /all_orders/{orderId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null;
    }

    // User profile and sub-collections
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /orders/{orderId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Username mapping
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bot sessions
    match /botSessions/{sessionId} {
      allow read, write: if request.auth != null && (request.auth.uid == sessionId || isAdmin());
    }

    // Global settings (Broadcast)
    match /settings/broadcast {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
