rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for User Profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      match /orders/{orderId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for Username Mapping.
     */
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    /**
     * @description Rules for Bot Sessions.
     */
    match /botSessions/{sessionId} {
      allow read, write: if true; // Webhook needs access
    }

    /**
     * @description Rules for Chat Logs.
     */
    match /chatSessions/{phoneNumber}/messages/{messageId} {
      allow create: if true;
      allow read: if isSignedIn();
    }

    /**
     * @description Global stats.
     */
    match /globalStats/{document} {
      allow read: if isSignedIn();
    }

    // --- Collection Group Rules ---
    // These must be at the top level to work for collectionGroup() queries.

    /**
     * @description Allows any signed-in user to perform collection group queries on 'orders'.
     */
    match /{path=**}/orders/{orderId} {
      allow list, get: if isSignedIn();
    }
    
    /**
     * @description Allows admin to see all chat messages via collection group.
     */
    match /{path=**}/messages/{messageId} {
      allow list, get: if isSignedIn();
    }
  }
}