rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP RULES (MUST BE TOP LEVEL) ---
    // These rules allow the Admin Dashboard to query all 'orders' and 'messages' across the DB.
    
    match /{allPaths=**}/orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    match /{allPaths=**}/messages/{messageId} {
      allow read, write: if true; 
    }

    // --- SPECIFIC PATH RULES ---

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /botSessions/{sessionId} {
      allow read, write: if true; 
    }

    match /chatSessions/{phoneNumber} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    match /globalStats/{document} {
      allow read: if request.auth != null;
    }
  }
}