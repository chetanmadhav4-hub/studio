rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model designed for a WhatsApp-based SMM automation bot. 
     * Security is centered around the user's identity (WhatsApp number), which serves as the Firebase UID.
     * 
     * DATA STRUCTURE:
     * All data is hierarchically organized under the top-level `/users/{userId}` collection. 
     * User profiles, active chat sessions, orders, and payment records are stored as subcollections 
     * within the specific user's document tree.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Authorization: Access is governed by matching the `userId` in the document path 
     *    directly against the `request.auth.uid`.
     * 2. Denormalized Identity: Every document contains a `userId` field. This allows for fast, 
     *    single-document checks without needing costly `get()` calls to parent documents.
     * 3. Structural Segregation: There is no public data in this model. All collections are 
     *    private and restricted to the owner.
     * 4. Prototyping Flexibility: Rules strictly enforce *who* can write (the owner), but do 
     *    not restrict the *shape* of the data (schema) to allow for rapid development iterations.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists. Used for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for User Profiles. Maps to UserProfile entity.
     * @path /users/{userId}
     * @allow get (read) if user is the owner of the profile.
     * @deny create if the authenticated UID does not match the document ID.
     * @principle Path-based ownership and relational integrity validation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for active conversational sessions. Maps to UserSession entity.
       * @path /users/{userId}/userSessions/{sessionId}
       * @allow create if user owns the parent path and provides their UID in the data.
       * @deny update if user attempts to change the ownership field (userId).
       * @principle Denormalized ownership validation and subcollection isolation.
       */
      match /userSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for SMM service orders. Maps to Order entity.
       * @path /users/{userId}/orders/{orderId}
       * @allow list if the user is the authenticated owner of the parent path.
       * @deny update if the document does not exist or UID is being changed.
       * @principle Ensures users can only manage their own service orders.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for payment transaction records. Maps to Payment entity.
       * @path /users/{userId}/payments/{paymentId}
       * @allow get if the user is the authenticated owner.
       * @deny delete if the user is not the owner of the payment record.
       * @principle Path-based access control for sensitive financial data.
       */
      match /payments/{paymentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}