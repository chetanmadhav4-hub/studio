rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for User Profiles.
     */
    match /users/{userId} {
      // Allow user to see and edit only their own profile
      allow get: if isOwner(userId);
      // Allow any logged in user to create their own profile during signup
      allow create: if isOwner(userId);
      // Only owner can update or delete
      allow update, delete: if isExistingOwner(userId);

      match /userSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }

      match /orders/{orderId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for Username Mapping (Uniqueness check).
     */
    match /usernames/{username} {
      // Allow anyone (even non-logged-in users) to check if a username exists
      // This is necessary for checking availability during signup and looking up email for login.
      allow get: if true;
      
      // Only the authenticated user can create their own username mapping
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      
      // Only the owner can update or delete their mapping
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}