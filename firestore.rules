rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP RULES ---
    // These must be at the top level and use the {path=**} syntax for group queries to work.

    /**
     * @description Allow signed-in users (Admins) to query all 'orders' collections across the database.
     */
    match /{path=**}/orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    /**
     * @description Allow querying all 'messages' collections for admin review or webhook processing.
     */
    match /{path=**}/messages/{messageId} {
      allow read, write: if request.auth != null || true; 
    }

    // --- SPECIFIC PATH RULES ---

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Note: This sub-match is still useful for direct document access by the owner
      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /botSessions/{sessionId} {
      allow read, write: if true; 
    }

    match /chatSessions/{phoneNumber} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    match /globalStats/{document} {
      allow read: if request.auth != null;
    }
  }
}