rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules (Must be at top level) ---

    /**
     * @description Allows any signed-in user (Admin) to perform collection group queries on 'orders'.
     */
    match /{anyPath=**}/orders/{orderId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    /**
     * @description Allows any signed-in user (Admin) to see all chat messages via collection group.
     */
    match /{anyPath=**}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if true; // Webhook needs to create
    }

    // --- Specific Collection Rules ---

    match /users/{userId} {
      allow get, create: if isOwner(userId);
      allow update, delete: if isOwner(userId);

      match /orders/{orderId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /botSessions/{sessionId} {
      allow read, write: if true; // Webhook and Admin need access
    }

    match /chatSessions/{phoneNumber} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if true;
      }
    }

    match /globalStats/{document} {
      allow read: if isSignedIn();
    }
  }
}