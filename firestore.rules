rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP RULES (MUST BE AT TOP) ---
    // These allow the Admin Dashboard to list documents across ALL paths
    
    match /{path=**}/orders/{orderId} {
      allow read, list: if request.auth != null;
    }
    
    match /{path=**}/messages/{messageId} {
      allow read, list: if true;
    }

    // --- SPECIFIC PATH RULES ---

    match /users/{userId} {
      // Allow any logged in user to read (for the admin user list)
      allow read, list: if request.auth != null;
      // Users can only write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;

      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /botSessions/{sessionId} {
      allow read, write: if true; 
    }

    match /chatSessions/{phoneNumber} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    match /globalStats/{document} {
      allow read: if request.auth != null;
    }
  }
}