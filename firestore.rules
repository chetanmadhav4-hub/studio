rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for User Profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      match /orders/{orderId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for Username Mapping.
     */
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    /**
     * @description Rules for Bot Sessions (Used by Webhook and Admin).
     */
    match /botSessions/{sessionId} {
      // Webhook creates/updates sessions anonymously
      allow get, create, update: if true;
      // Admin lists sessions
      allow list: if isSignedIn();
    }

    /**
     * @description Rules for Chat Logs.
     */
    match /chatSessions/{phoneNumber}/messages/{messageId} {
      // Webhook and Admin can log messages
      allow create: if true;
      // Admin reads logs
      allow get, list: if isSignedIn();
    }

    /**
     * @description Global stats.
     */
    match /globalStats/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- Collection Group Rules (Crucial for Dashboard) ---

    /**
     * @description Allows any signed-in user to perform collection group queries on 'orders'.
     * This is required for the Admin Dashboard to see all orders from all users.
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isSignedIn();
    }
    
    /**
     * @description Allows admin to see all chat messages via collection group if needed.
     */
    match /{path=**}/messages/{messageId} {
      allow read: if isSignedIn();
    }
  }
}