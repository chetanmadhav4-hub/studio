rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Collection Group Rules (Must be at top level for group queries) ---

    /**
     * @description Allows any signed-in user (Admin) to perform collection group queries on 'orders'.
     */
    match /{path=**}/orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    /**
     * @description Allows any signed-in user (Admin) to see all chat messages via collection group.
     */
    match /{path=**}/messages/{messageId} {
      allow read, write: if request.auth != null || true; // Allow webhook/public creation
    }

    // --- Specific Collection Rules ---

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /botSessions/{sessionId} {
      allow read, write: if true; 
    }

    match /chatSessions/{phoneNumber} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    match /globalStats/{document} {
      allow read: if request.auth != null;
    }
  }
}