rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for User Profiles.
     */
    match /users/{userId} {
      // Allow user to see and edit only their own profile
      allow get: if isOwner(userId);
      // Allow any logged in user to create their own profile during signup
      allow create: if isOwner(userId);
      // Only owner can update or delete
      allow update, delete: if isExistingOwner(userId);

      match /orders/{orderId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for Username Mapping.
     */
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    /**
     * @description Rules for Bot Sessions (Needed by Webhook and Admin).
     */
    match /botSessions/{sessionId} {
      // Webhook needs to create/update sessions without being logged in (as a background service)
      // In a production app, we'd verify the request origin, but for this prototype we allow it.
      allow get, create, update: if true;
      // Admin needs to list all sessions
      allow list: if isSignedIn();
    }

    /**
     * @description Rules for Chat Logs.
     */
    match /chatSessions/{phoneNumber}/messages/{messageId} {
      // Webhook logs messages
      allow create: if true;
      // Admin reads logs
      allow get, list: if isSignedIn();
    }

    /**
     * @description Collection Group rules for Orders (needed for Admin Dashboard).
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isSignedIn();
    }
    
    /**
     * @description Global stats.
     */
    match /globalStats/{document} {
      allow read: if isSignedIn();
      allow write: if false; // Only updated via backend logic if we had any
    }
  }
}