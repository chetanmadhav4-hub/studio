
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Master collection of orders for the admin tracker
    match /all_orders/{orderId} {
      // Only admin can read and update (approve/reject)
      allow read, update: if request.auth != null && request.auth.token.email == 'chetanmadhav4@gmail.com';
      // Bot (webhook) or anyone can create an entry when ordering
      allow create: if true;
    }

    // User profile and sub-collections
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /orders/{orderId} {
        allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'chetanmadhav4@gmail.com');
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Username mapping
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bot sessions
    match /botSessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
