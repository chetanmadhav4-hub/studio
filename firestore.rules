
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Master collection of orders for the admin tracker
    match /all_orders/{orderId} {
      // Allow admin (Chetan) to read and manage everything
      allow read, update, delete: if request.auth != null && request.auth.token.email == 'chetanmadhav4@gmail.com';
      // Allow creation for anyone during the order flow (bot/preview)
      allow create: if true;
    }

    // User profile and sub-collections
    match /users/{userId} {
      // Admin or user themselves can read
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'chetanmadhav4@gmail.com');
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /orders/{orderId} {
        allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'chetanmadhav4@gmail.com');
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Username mapping
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bot sessions - needed for notifications and flow
    match /botSessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
