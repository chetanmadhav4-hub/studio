
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information and links username to UID.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "createdAt"]
    },
    "UsernameMap": {
      "title": "UsernameMap",
      "description": "A lookup table to ensure username uniqueness and map username to email.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["email", "uid"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Individual user profiles."
    },
    "/usernames/{username}": {
      "schema": { "$ref": "#/backend/entities/UsernameMap" },
      "description": "Ensures username uniqueness and provides email lookup for login."
    }
  }
}
