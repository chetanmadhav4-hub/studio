
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information and links username to UID.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "createdAt"]
    },
    "UsernameMap": {
      "title": "UsernameMap",
      "description": "A lookup table to ensure username uniqueness and map username to email.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["email", "uid"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents an SMM order placed by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["COMPLETED", "PROCESSING", "PENDING"] },
        "targetLink": { "type": "string" },
        "utrId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "serviceName", "quantity", "price", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Individual user profiles."
    },
    "/usernames/{username}": {
      "schema": { "$ref": "#/backend/entities/UsernameMap" },
      "description": "Ensures username uniqueness and provides email lookup for login."
    },
    "/users/{uid}/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "User's individual SMM orders."
    }
  }
}
